name = "union-roleplay-api"
main = "worker.js"
compatibility_date = "2026-07-01"

[vars]
SITE_URL = "https://YOUR-GITHUB-USERNAME.github.io/YOUR-REPOSITORY"
DISCORD_CLIENT_ID = "YOUR_DISCORD_APPLICATION_CLIENT_ID"
DISCORD_GUILD_ID = "YOUR_DISCORD_SERVER_ID"
DISCORD_REDIRECT_URI = "https://YOUR-WORKER.workers.dev/auth/callback"
STAFF_ROLE_IDS = "ROLE_ID_1,ROLE_ID_2"

[[d1_databases]]
binding = "DB"
database_name = "union-submissions"
database_id = "YOUR_D1_DATABASE_ID"
